<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.media.MediaView?>

<AnchorPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.MenuController">

    <StackPane alignment="CENTER" styleClass="video-container" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <MediaView fx:id="backgroundView" blendMode="COLOR_BURN" fitHeight="220.0" fitWidth="460.0" preserveRatio="true" />
        <StackPane mouseTransparent="true" prefHeight="320.0" prefWidth="520.0" styleClass="video-vignette" />
    </StackPane>

    <Label alignment="CENTER" styleClass="menu-title" text="HANGCAT" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="36.0" />

    <HBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="140.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <Button fx:id="btnEasy" mnemonicParsing="false" onAction="#setEasy" prefHeight="45.0" prefWidth="120.0" styleClass="menu-button" text="EASY" />
        <Button fx:id="btnMedium" mnemonicParsing="false" onAction="#setMedium" prefHeight="45.0" prefWidth="120.0" styleClass="menu-button" text="MEDIUM" />
        <Button fx:id="btnHard" mnemonicParsing="false" onAction="#setHard" prefHeight="45.0" prefWidth="120.0" styleClass="menu-button" text="HARD" />
    </HBox>

    <StackPane prefHeight="60.0" prefWidth="220.0" AnchorPane.bottomAnchor="60.0" AnchorPane.leftAnchor="340.0">
        <Button mnemonicParsing="false" onAction="#handleStart" prefHeight="55.0" prefWidth="220.0" styleClass="menu-button" text="PLAY" />
    </StackPane>

</AnchorPane>
